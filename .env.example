# Game of Memes - Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env with real secrets.

# ─── Node ───────────────────────────────────────
NODE_ENV=development

# ─── Supabase ───────────────────────────────────
# Get these from: https://supabase.com/dashboard > Your Project > Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ─── Auth (Privy) ──────────────────────────────
# Get these from: https://dashboard.privy.io/ > Your App > Settings
NEXT_PUBLIC_PRIVY_APP_ID=your-privy-app-id
PRIVY_APP_ID=your-privy-app-id
PRIVY_SECRET_KEY=your-privy-secret-key

# ─── Web3 / RPC ────────────────────────────────
# Get from: https://dashboard.alchemy.com/
NEXT_PUBLIC_ALCHEMY_API_KEY=your-alchemy-key
NEXT_PUBLIC_ALCHEMY_ID=your-alchemy-key

# Get from: https://cloud.walletconnect.com/
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=your-walletconnect-project-id
NEXT_PUBLIC_WC_PROJECT_ID=your-walletconnect-project-id
NEXT_PUBLIC_WALLET_CONNECT_PROJECT_ID=your-walletconnect-project-id

# Chain configuration
NEXT_PUBLIC_ENABLE_TESTNETS=true
NEXT_PUBLIC_DEFAULT_CHAIN=base

# ─── NFT Contracts (Base Mainnet) ──────────────
NEXT_PUBLIC_AQUAPRIME_NFT_CONTRACT=0x3e7A0f61A9889BFC6b8A9f356F9CC57299762369
NEXT_PUBLIC_MOONSTONE_CONTRACT=0x491607a777AedAb22e5409820eF5386fBFE7F360

# ─── VibeMarket / Wield API ────────────────────
# Get from: https://vibemarket.wieldlabs.com/
WIELD_API_KEY=your-wield-api-key

# ─── AI (Server-side only) ─────────────────────
# Get from: https://platform.openai.com/api-keys
# Used for AI deck generation. Optional for basic gameplay.
OPENAI_API_KEY=your-openai-key

# ─── Voice (Server-side only, optional) ────────
# Get from: https://deepgram.com/
DEEPGRAM_API_KEY=your-deepgram-key

# Get from: https://elevenlabs.io/
ELEVENLABS_API_KEY=your-elevenlabs-key

# ─── LiveKit (optional, for voice chat) ────────
# Get from: https://livekit.io/
LIVEKIT_API_KEY=your-livekit-key
LIVEKIT_API_SECRET=your-livekit-secret
NEXT_PUBLIC_LIVEKIT_URL=wss://your-livekit-url.livekit.cloud

# ─── IPFS / Pinata (optional) ──────────────────
# Get from: https://pinata.cloud/
PINATA_API_KEY=your-pinata-key
PINATA_API_SECRET=your-pinata-secret
PINATA_JWT=your-pinata-jwt
NEXT_PUBLIC_PINATA_GATEWAY=https://your-gateway.mypinata.cloud

# ─── JWT ────────────────────────────────────────
# Generate with: openssl rand -base64 64
JWT_SECRET=your-jwt-secret

# ─── Cron (Vercel) ─────────────────────────────
# Generate with: openssl rand -base64 32
CRON_SECRET=your-cron-secret

# ─── Twitter/X (optional, for social features) ─
TWITTER_API_KEY=your-twitter-key
TWITTER_API_SECRET=your-twitter-secret
TWITTER_ACCESS_TOKEN=your-twitter-access-token
TWITTER_ACCESS_TOKEN_SECRET=your-twitter-access-token-secret

# ─── API ────────────────────────────────────────
API_HOSTNAME=https://your-api-hostname.example.com
NEXT_PUBLIC_API_BASE_URL=http://localhost:3000/api
ALLOWED_ORIGINS=http://localhost:3000

# ─── Admin ──────────────────────────────────────
# Comma-separated wallet addresses with admin access
SUPER_ADMIN_ADDRESSES=0xYourWalletAddress
NEXT_PUBLIC_AUTHORIZED_ADDRESSES=0xYourWalletAddress

# ─── Telemetry ──────────────────────────────────
NEXT_TELEMETRY_DISABLED=1
